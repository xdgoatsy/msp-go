# 环境变量配置示例（单一 .env）
# 开发与生产都使用同一个 .env 文件
# 通过 ENVIRONMENT 和 DEBUG 区分运行模式

# 应用配置
DEBUG=true
ENVIRONMENT=development
LLM_POOL_WARMUP_ENABLED=false

# 服务端口
PY_AI_PORT=8000

# 数据库配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=math_platform

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 加密配置
FERNET_SECRET_KEY=dev-fernet-key-change-in-production

# CORS 配置（开发环境 - 允许 Vite 开发服务器）
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:3000"]

# 初始管理员配置
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# AI 配置（可选）
# OPENAI_API_KEY=your-api-key-here
# OPENAI_API_BASE=https://api.openai.com/v1

# 存储后端配置（"local"、"qiniu" 或 "s3"）
STORAGE_BACKEND=local

# 七牛云对象存储配置（STORAGE_BACKEND=qiniu 时必填）
# 在七牛云控制台 -> 密钥管理 中获取
QINIU_ACCESS_KEY=your-access-key-here
QINIU_SECRET_KEY=your-secret-key-here
# 存储空间名称（Bucket Name）
QINIU_BUCKET_NAME=your-bucket-name
# 绑定的访问域名（含协议，如 https://cdn.example.com）
QINIU_DOMAIN=https://your-cdn-domain.com
# 是否为私有空间（true/false）
QINIU_PRIVATE_BUCKET=false
# 私有空间下载链接有效期（秒，默认 3600）
QINIU_URL_EXPIRE_SECONDS=3600

# S3 兼容对象存储配置（STORAGE_BACKEND=s3 时必填）
# 支持 AWS S3、阿里云 OSS、腾讯云 COS、MinIO、中国科技云等
# S3 端点 URL（如 https://s3.cstcloud.cn 或 https://s3.amazonaws.com）
S3_ENDPOINT_URL=https://s3.cstcloud.cn
# S3 Access Key ID
S3_ACCESS_KEY=your-access-key-here
# S3 Secret Access Key
S3_SECRET_KEY=your-secret-key-here
# 存储桶名称
S3_BUCKET_NAME=your-bucket-name
# 区域（默认 us-east-1，某些服务可能不需要）
S3_REGION=us-east-1
# 公开访问的 CDN 域名（可选，如 https://cdn.example.com）
S3_PUBLIC_URL_BASE=
# 是否为私有桶（true/false）
S3_PRIVATE_BUCKET=false
# 私有桶预签名 URL 有效期（秒，默认 3600）
S3_URL_EXPIRE_SECONDS=3600
